APP_NAME=Civic Access Index
APP_ENV=local
APP_VERSION=0.1.0
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://civic:civic@postgres:5432/civic_access
ASYNC_DATABASE_URL=postgresql+asyncpg://civic:civic@postgres:5432/civic_access
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
OPENSEARCH_URL=http://opensearch:9200

RAW_SNAPSHOT_BUCKET=local-civic-access-raw
RAW_SNAPSHOT_ROOT=local-data/raw-snapshots
ADMIN_TOKEN=change-me
ENABLE_OPENSEARCH=false

